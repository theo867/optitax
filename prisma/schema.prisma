generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role         @default(USER)
  accounts      Account[]
  sessions      Session[]
  simulations   Simulation[]
  leads         Lead[]
  adminLogs     AdminLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Simulation {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  canton           String
  commune          String
  taxableIncome    Int
  taxableWealth    Int
  estimatedTax     Int
  potentialSavings Int
  score            Int
  input            Json
  result           Json
  leads            Lead[]
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model RecommendationContent {
  id          String   @id
  title       String
  description String
  guide       Json
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  simulationId String?
  simulation   Simulation? @relation(fields: [simulationId], references: [id], onDelete: SetNull)
  name      String
  email     String
  phone     String?
  canton    String
  savings   Int
  message   String?
  consent   Boolean  @default(false)
  status    LeadStatus @default(NEW)
  createdAt DateTime @default(now())

  @@index([canton, createdAt])
  @@index([simulationId])
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum Role {
  USER
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ARCHIVED
}
